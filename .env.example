# ── Authentication ────────────────────────────────────────────────────────────
# Random secret for signing JWT tokens (min 32 chars)
# Generate with: openssl rand -base64 32
AUTH_SECRET=your-secret-min-32-chars-here

# Admin panel password
ADMIN_PASSWORD=your-strong-admin-password

# ── Database (Turso SQLite) ────────────────────────────────────────────────────
# Get started: https://turso.tech — free tier is ample for this app
# Create: turso db create recs-for-kids
TURSO_DATABASE_URL=libsql://your-db-name-yourname.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# ── Email (Gmail with App Password) ──────────────────────────────────────────
# Your Gmail address (used as both sender and SMTP login)
GMAIL_USER=your-gmail-address@gmail.com

# Gmail App Password — NOT your regular Gmail password
# Generate one at: Google Account → Security → 2-Step Verification → App passwords
# Create an app named "Family Adventures" → copy the 16-character password
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ── APIs ──────────────────────────────────────────────────────────────────────
# Anthropic Claude API (for activity generation)
# https://console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-api-key

# Google Places API (for finding real nearby venues)
# Enable "Places API (New)" at https://console.cloud.google.com
# $200/month free credit covers typical usage easily
GOOGLE_PLACES_API_KEY=your-google-places-api-key

# OpenWeatherMap API (free tier is sufficient)
# https://openweathermap.org/api
OPENWEATHER_API_KEY=your-openweathermap-api-key

# ── App URL ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://adventures.robgregg.com

# ── Seed users (optional) ─────────────────────────────────────────────────────
# Primary admin (default: mail@robgregg.com) — set is_admin = 1
SEED_EMAIL=mail@robgregg.com
# Secondary user granted access on first schema init — leave blank if not needed
SEED_USER_2=

# ── Optional: local events APIs ──────────────────────────────────────────────
# Eventbrite API key for structured family event data (optional; app works without it)
# https://www.eventbrite.com/platform/api
EVENTBRITE_API_KEY=

# Serper.dev API key for web-search-based event discovery (optional)
# https://serper.dev
SERPER_API_KEY=
